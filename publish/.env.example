# Copy this file to repository root as .env and fill the command templates.
# Placeholders available in each command:
# {file} {source} {title} {slug} {platform}
# Do NOT `source` this file in shell directly; use publish runner to load it.

# ------------------------------------------------------------
# Feishu
# ------------------------------------------------------------
# create | append
FEISHU_DOC_MODE=create
# Required when FEISHU_DOC_MODE=append
FEISHU_DOC_ID=
# Optional folder token when create
FEISHU_FOLDER_TOKEN=
# Optional: override md2feishu-doc skill path
MD2FEISHU_SKILL_DIR=/Users/zenghao/.agents/skills/md2feishu-doc

# Uses wrapper script in this repo.
PUBLISH_FEISHU_CMD=node scripts/post-feishu.js --input {file} --source {source} --mode create --execute --submit

# ------------------------------------------------------------
# WeChat
# ------------------------------------------------------------
# article | image-text
WECHAT_PUBLISH_MODE=article
# Optional: custom theme for article mode
# doocs: default|grace|simple
# mdnice-inspired: mdnice-simple|mdnice-lanqing
WECHAT_ARTICLE_THEME=mdnice-simple
# Optional: custom Chrome profile dir for WeChat automation.
# Default when empty: ~/.local/share/wechat-browser-profile
WECHAT_CHROME_PROFILE=
# Optional overrides
WECHAT_AUTHOR=
WECHAT_SUMMARY=
WECHAT_IMAGES_DIR=
# Optional audit artifacts (draft screenshot + metrics report)
WECHAT_AUDIT_DIR=
WECHAT_AUDIT_PREFIX=
# Optional: auto-generate/apply cover for article draft
WECHAT_AUTO_COVER_GLM=false
# Optional: use existing local cover image (skip GLM generation)
WECHAT_COVER_IMAGE=
# Optional: generated cover output dir
WECHAT_COVER_OUTPUT_DIR=publish/output/wechat/cover
# Cover generator engine: gemini-cli|glm
WECHAT_COVER_ENGINE=gemini-cli
# Generate multiple variants then auto-pick best by score
WECHAT_COVER_VARIANTS=1
# Scorer: codex-cli|auto|heuristic|none
WECHAT_COVER_SCORER=codex-cli
# Optional scorer model (for codex-cli)
WECHAT_COVER_SCORE_MODEL=
# Timeout per codex scoring call (ms)
WECHAT_COVER_SCORE_TIMEOUT_MS=120000
# Timeout per gemini generation call (ms)
WECHAT_COVER_GEMINI_TIMEOUT_MS=600000
# Fallback to GLM when gemini timeout/failure (recommended true)
WECHAT_COVER_GEMINI_FALLBACK_GLM=true
# Optional CLI binaries / paths
WECHAT_COVER_GEMINI_BIN=gemini
WECHAT_COVER_GEMINI_INCLUDE_DIRS=/Users/zenghao/.baoyu-skills
WECHAT_COVER_CODEX_BIN=codex
WECHAT_COVER_CODEX_CD=
# Optional: GLM image generation params
WECHAT_COVER_MODEL=glm-image
WECHAT_COVER_SIZE=1888x800
WECHAT_COVER_QUALITY=hd
WECHAT_COVER_PROMPT=
# Optional: remove model watermark by trimming right-bottom corner before final crop
WECHAT_COVER_REMOVE_WATERMARK=true
# Prefer ratio-based trim (used when *_PX is 0)
WECHAT_COVER_WATERMARK_TRIM_RIGHT_RATIO=0.08
WECHAT_COVER_WATERMARK_TRIM_BOTTOM_RATIO=0.10
# Absolute trim px (0 means use ratio)
WECHAT_COVER_WATERMARK_TRIM_RIGHT_PX=0
WECHAT_COVER_WATERMARK_TRIM_BOTTOM_PX=0
# Prefer this ratio when selecting from content image list
WECHAT_COVER_PREFER_RATIO=2.35
# Optional: explicit API key (fallback to ~/.config/glm-claude/config.json)
WECHAT_GLM_API_KEY=
# Optional: override GLM image API endpoint
WECHAT_GLM_BASE_URL=https://api.z.ai/api/paas/v4/images/generations
# Whether to crop generated image to 900x383 via sips on macOS
WECHAT_COVER_CROP_900383=true
# Optional: override skill path
BAOYU_POST_TO_WECHAT_SKILL_DIR=/Users/zenghao/.agents/skills/baoyu-skills/skills/baoyu-post-to-wechat

# Uses wrapper script in this repo.
PUBLISH_WECHAT_CMD=node scripts/post-wechat.js --input {file} --source {source} --mode article --execute --submit

# ------------------------------------------------------------
# Xiaohongshu
# ------------------------------------------------------------
PUBLISH_XHS_CMD=

# ------------------------------------------------------------
# X/Twitter
# ------------------------------------------------------------
# article | tweet
X_PUBLISH_MODE=article
# Optional: custom Chrome profile dir for X automation.
# Default when empty: ~/.local/share/x-browser-profile
X_CHROME_PROFILE=
# Auto post one short promo tweet after successful article publish (true|false)
X_ARTICLE_AUTO_PROMO=true
# Optional promo template. Available placeholders: {title} {summary} {link}
X_ARTICLE_PROMO_TEMPLATE=
# Optional hard override promo text (higher priority than template)
X_ARTICLE_PROMO_TEXT=
# Whether promo tweet should attach the first local image (true|false)
X_ARTICLE_PROMO_USE_IMAGE=false
# Optional: override skill path
BAOYU_POST_TO_X_SKILL_DIR=/Users/zenghao/.agents/skills/baoyu-skills/skills/baoyu-post-to-x

# Uses wrapper script in this repo.
PUBLISH_X_CMD=node scripts/post-x.js --input {file} --source {source} --mode article --execute --submit
